{
  "name": "cyanium-design-system",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codyrobertson/cyanium-design-system.git"
  },
  "bugs": {
    "url": "https://github.com/codyrobertson/cyanium-design-system/issues"
  },
  "homepage": "https://github.com/codyrobertson/cyanium-design-system#readme",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build:registry": "node scripts/build-registry.mjs",
    "check:registry": "node scripts/check-registry.mjs",
    "storybook": "pnpm --filter @cyanium/docs dev",
    "example": "pnpm --filter example dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  },
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  }
}
